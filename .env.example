PORT=4001
VITE_PORT=5175
VITE_API_URL=http://localhost:4001
NODE_ENV=development
VITE_PLUGINS_ENABLED=true
VITE_AUTOLOAD_PLUGINS=dummy

# AIDA / MAIA
# Server-side gate for operator actions such as manual asset add/edit/delete/presets.
# When false or unset, read-only observation still works: manual asset list,
# refresh, and MAIA memory context remain available.
KESTREL_WORKFLOW_ACTIONS=false

# Client-side visibility flag for AIDA operator controls.
# Set this with KESTREL_WORKFLOW_ACTIONS=true when testing manual asset actions locally.
VITE_FF_WORKFLOW_ACTIONS=false

# Optional AIDA radar feature flags.
VITE_FF_AIDA_RADAR=false
VITE_FF_SHOW_CALIBRATION=false
VITE_FF_CANVAS_LAYER=false

# Optional server/provider flags. Keep disabled unless actively testing providers.
KESTREL_AI_BROKER_ENABLED=false
KESTREL_OLLAMA_ENABLED=false
